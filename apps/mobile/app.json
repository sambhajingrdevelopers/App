{
  "expo": {
    "name": "VibeLoop",
    "slug": "vibeloop",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "vibeloop",
    "userInterfaceStyle": "dark",
    "platforms": ["ios", "android", "web"],
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#09090f"
      }
    }
  }
}
