# App
APP_NAME=VibeLoop
APP_ENV=development

# Backend
API_BASE_URL=http://localhost:8000
JWT_SECRET=change_this_secret

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/vibeloop

# Storage
STORAGE_PROVIDER=local
STORAGE_BUCKET=vibeloop-media

# Supabase optional
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Admin Security
JWT_SECRET_KEY=change-this-long-random-secret
ADMIN_EMAIL=admin@vibeloop.app
ADMIN_PASSWORD=Admin@12345
ADMIN_API_KEY=CHANGE_ME_ADMIN_KEY
